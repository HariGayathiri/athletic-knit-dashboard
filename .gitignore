# ============================================================
# ATHLETIC KNIT CRM DASHBOARD — .gitignore
# ============================================================

# Node packages — Vercel installs these automatically on deploy
node_modules/

# Built production output — Vercel builds this automatically
dist/

# Secret keys and tokens — NEVER commit these to GitHub
# Set HUBSPOT_PRIVATE_TOKEN in Vercel Dashboard > Environment Variables
.env
.env.local
.env.production
.env.development.local

# OS system files
.DS_Store
Thumbs.db

# VS Code personal settings
.vscode/

# Logs
*.log
npm-debug.log*
