# ============================================================
# ATHLETIC KNIT CRM DASHBOARD — .gitignore
# ============================================================

# Node packages (never upload — Netlify installs automatically)
node_modules/
netlify/functions/node_modules/

# Built production output (never upload — Netlify builds this)
dist/

# Secret keys and tokens (NEVER commit to GitHub)
.env
.env.local
.env.production
.env.development.local

# OS system files
.DS_Store
Thumbs.db

# VS Code personal settings
.vscode/

# Logs
*.log
npm-debug.log*
